{
  "name": "drone-control-station",
  "version": "0.1.0",
  "private": true,
  "description": "Local Electron control station for WIFI_8K drone experiments.",
  "main": "electron/main.js",
  "scripts": {
    "start": "npm run ui:build && electron --no-sandbox .",
    "ui:install": "npm --prefix ui install",
    "ui:build": "npm --prefix ui run build",
    "ui:dev": "npm --prefix ui run dev",
    "check": "node --check electron/main.js && node --check electron/preload.js"
  },
  "devDependencies": {
    "electron": "^39.2.4"
  }
}
